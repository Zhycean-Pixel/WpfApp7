<Window x:Class="WpfApp7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp7"
        mc:Ignorable="d"
        Title="UDI 标签打印系统 - 登录" Height="400" Width="600" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Background="#F0F2F5">
        <!-- 定义阴影效果的边框 -->
            <StackPanel Margin="30">
                <!-- 标题 -->
            <TextBlock Text="UDI 系统登录" FontSize="24" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center" Margin="0,0,0,25"/>
            <!-- 用户名 -->
                <TextBlock Text="用户名" Foreground="#666666" Margin="0,0,0,5"/>
            <TextBox Text="{Binding UserName , UpdateSourceTrigger=PropertyChanged}" 
                         Height="35" VerticalContentAlignment="Center" Margin="0,0,0,15" Padding="5,0"/>
            <!-- 密码 -->
                <TextBlock Text="密码" Foreground="#666666" Margin="0,0,0,5"/>
            <TextBox Text="{Binding PassWord , UpdateSourceTrigger=PropertyChanged}" 
                         Height="35" VerticalContentAlignment="Center" Margin="0,0,0,15" Padding="5,0"/>
            <!-- 登录按钮 -->
            <Button     Command="{Binding LoginCommand}"
                        Content="登 录" 
                        Height="40" 
                        Background="#0078D7" 
                        Foreground="White" 
                        FontSize="16" 
                        FontWeight="SemiBold"
                        Cursor="Hand">
                </Button>
            </StackPanel>
    </Grid>
</Window>